# Database Configuration (Get this from your Neon dashboard)
DATABASE_URL="postgresql://<user>:<password>@<ep-name>.neon.tech/vera_db?sslmode=require"

# LLM Configuration
LLM_PROVIDER="openai" # Change to anthropic, gemini, etc. based on your choice
LLM_API_KEY="your_api_key_here"

# Application Settings
ENVIRONMENT="development"
PORT=8080